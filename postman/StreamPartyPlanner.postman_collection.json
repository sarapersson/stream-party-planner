    {
      "name": "Create valid watch party",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const scheduledAt = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString();",
              "pm.environment.set(\"scheduledAt\", scheduledAt);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Location header exists\", function () {",
              "  pm.expect(pm.response.headers.has(\"Location\")).to.be.true;",
              "});",
              "",
              "pm.test(\"Response has string id\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property(\"id\").that.is.a(\"string\");",
              "});",
              "",
              "pm.test(\"Response fields match request\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.title).to.eql(\"Postman Sci-Fi Watch Party\");",
              "  pm.expect(json.description).to.eql(\"Created by the Postman collection.\");",
              "  pm.expect(json.scheduledAt).to.eql(pm.environment.get(\"scheduledAt\"));",
              "  pm.expect(json.genre).to.eql(\"Sci-Fi\");",
              "  pm.expect(json.maxParticipants).to.eql(8);",
              "});",
              "",
              "pm.test(\"Status is PLANNED\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql(\"PLANNED\");",
              "});",
              "",
              "pm.test(\"Timestamps exist\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property(\"createdAt\");",
              "  pm.expect(json).to.have.property(\"updatedAt\");",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.environment.set(\"watchPartyId\", json.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Postman Sci-Fi Watch Party\",\n  \"description\": \"Created by the Postman collection.\",\n  \"scheduledAt\": \"{{scheduledAt}}\",\n  \"genre\": \"Sci-Fi\",\n  \"maxParticipants\": 8\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/watch-parties",
          "host": [
