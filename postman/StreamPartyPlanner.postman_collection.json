              "});",
              "",
              "pm.test(\"Response id matches environment id\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.id).to.eql(pm.environment.get(\"watchPartyId\"));",
              "});",
              "",
              "pm.test(\"Response has expected core fields\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.include.keys(",
              "    \"id\",",
              "    \"title\",",
              "    \"description\",",
              "    \"scheduledAt\",",
              "    \"genre\",",
              "    \"maxParticipants\",",
              "    \"status\",",
              "    \"createdAt\",",
              "    \"updatedAt\"",
              "  );",
              "  pm.expect(json.title).to.eql(\"Postman Sci-Fi Watch Party\");",
              "  pm.expect(json.status).to.eql(\"PLANNED\");",
              "});"
            ]
          }
        }
      ]
