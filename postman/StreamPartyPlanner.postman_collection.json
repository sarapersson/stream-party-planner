    {
      "name": "Update created watch party",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const updatedScheduledAt = new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toISOString();",
              "pm.environment.set(\"updatedScheduledAt\", updatedScheduledAt);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response id matches environment id\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.id).to.eql(pm.environment.get(\"watchPartyId\"));",
              "});",
              "",
              "pm.test(\"Updated fields match request\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.title).to.eql(\"Updated Postman Sci-Fi Watch Party\");",
              "  pm.expect(json.description).to.eql(\"Updated by the Postman collection.\");",
              "  pm.expect(json.scheduledAt).to.eql(pm.environment.get(\"updatedScheduledAt\"));",
              "  pm.expect(json.genre).to.eql(\"Sci-Fi\");",
              "  pm.expect(json.maxParticipants).to.eql(10);",
              "});",
              "",
              "pm.test(\"Status is LIVE\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql(\"LIVE\");",
              "});",
              "",
              "pm.test(\"Timestamps exist\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property(\"createdAt\");",
              "  pm.expect(json).to.have.property(\"updatedAt\");",
              "});"
            ]
          }
        }
      ],
